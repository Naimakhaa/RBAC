<div class="bg-white p-6 rounded shadow">
  <h2 class="text-xl font-bold mb-4">Tambah User</h2>

  <form action="/users" method="POST" class="mb-6 space-y-3">
    <input 
      type="text" 
      name="username" 
      placeholder="Username"
      class="border p-2 w-full"
      required
    >

    <input 
      type="password" 
      name="password" 
      placeholder="Password"
      class="border p-2 w-full"
      required
    >

    <select name="role_id" class="border p-2 w-full" required>
      <% roles.forEach(role => { %>
        <option value="<%= role.id %>"><%= role.name %></option>
      <% }) %>
    </select>

    <button class="bg-blue-600 text-white px-4 py-2 rounded">
      Simpan
    </button>
  </form>

  <h2 class="text-xl font-bold mb-4">Daftar User</h2>

  <table class="w-full border">
    <thead>
      <tr class="bg-gray-500">
        <th class="border p-2">ID</th>
        <th class="border p-2">Username</th>
        <th class="border p-2">Role</th>
        <th class="border p-2">Aksi</th>
      </tr>
    </thead>

    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td class="border p-2"><%= user.id %></td>
          <td class="border p-2"><%= user.username %></td>
          <td class="border p-2"><%= user.role_name %></td>
          <td class="border p-2">
            <form action="/users/delete/<%= user.id %>" method="POST">
              <button class="bg-red-600 text-white px-3 py-1 rounded">
                Hapus
              </button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>